# Mode front-only : données + auth via localStorage (sans backend)
NEXT_PUBLIC_USE_MOCK=true

# Mode hors ligne back-office (manager/admin/super-admin). false pour désactiver.
NEXT_PUBLIC_OFFLINE_ENABLED=true

# Ignoré en mode mock ; requis si NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_API_URL=http://localhost:8081

# Test offline shell (navigation pages) : le Service Worker est désactivé en `next dev`.
# Utiliser : npm run preview:offline  (build + start production sur le port 3001)
